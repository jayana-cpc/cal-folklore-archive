FROM mysql:8.0.45

# Keep auth plugin consistent
CMD ["mysqld", "--default-authentication-plugin=mysql_native_password"]

# Full DB snapshot on first start (replaces initial_setup + dev_seed).
# Re-seed: docker compose down -v && docker compose build db && docker compose up -d
COPY migrations/kfolkcdh_custom.sql /docker-entrypoint-initdb.d/10_kfolkcdh_seed.sql
